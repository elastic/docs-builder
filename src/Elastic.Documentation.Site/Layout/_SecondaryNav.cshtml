@using System.Linq
@inherits RazorSlice<Elastic.Documentation.Site.GlobalLayoutViewModel>
<div class="md:sticky md:top-0 md:z-30 bg-grey-10">
	<ask-ai></ask-ai>
	<nav id="secondary-nav" hx-select-oob="#main-container" hx-swap="none"
	     class="bg-grey-10 border-b border-grey-20">
		<div class="w-full max-w-(--max-layout-width) mx-auto px-4 h-[55px] flex items-center">
			@if (Model.NavV2Sections is { Count: > 0 } navTabs)
			{
				<ul class="flex gap-6 font-sans font-semibold text-sm text-ink-light md:text-base">
				@foreach (var navTab in navTabs.Where(s => !s.Isolated))
				{
					var isAbsolute = navTab.Url.StartsWith("http", StringComparison.OrdinalIgnoreCase);
					var isActive = !isAbsolute && navTab.Id == Model.ActiveSectionId;
					<li class="text-nowrap @(isActive ? "text-blue-elastic" : "hover:text-blue-elastic active:text-blue-elastic-100")"
						data-section-id="@navTab.Id">
						@if (isAbsolute)
						{
							<a href="@navTab.Url">@navTab.Label</a>
						}
						else
						{
							<a
								href="@Model.Link(navTab.Url)"
								@Model.Htmx.GetHxAttributes(
									hxSwapOob: "#main-container,#secondary-nav"
								)
							>
								@navTab.Label
							</a>
						}
					</li>
				}
				</ul>
			}
			else
			{
				<ul class="flex gap-6 font-sans font-semibold text-sm text-ink-light md:text-base">
					<li class="text-nowrap text-blue-elastic">
						<a href="@Model.Link("/")">Docs</a>
					</li>
					<li class="text-nowrap hover:text-blue-elastic active:text-blue-elastic-100">
						<a
							href="@Model.Link("/release-notes/")"
							@Model.Htmx.GetHxAttributes(hxSwapOob: "#main-container,#secondary-nav")
						>Release notes</a>
					</li>
					<li class="text-nowrap hover:text-blue-elastic active:text-blue-elastic-100">
						<a
							href="@Model.Link("/troubleshoot/")"
							@Model.Htmx.GetHxAttributes(hxSwapOob: "#main-container,#secondary-nav")
						>Troubleshoot</a>
					</li>
					<li class="text-nowrap hover:text-blue-elastic active:text-blue-elastic-100">
						<a
							href="@Model.Link("/reference/")"
							@Model.Htmx.GetHxAttributes(hxSwapOob: "#main-container,#secondary-nav")
						>Reference</a>
					</li>
				</ul>
			}
		</div>
	</nav>
</div>

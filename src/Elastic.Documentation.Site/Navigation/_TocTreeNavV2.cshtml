@using Elastic.Documentation.Navigation
@using Elastic.Documentation.Navigation.Isolated
@using Elastic.Documentation.Navigation.Isolated.Leaf
@using Elastic.Documentation.Navigation.V2
@using Elastic.Documentation.Site.Navigation
@inherits RazorSlice<NavigationTreeItem>
@{
	var isTopLevel = Model.Level == 0 && Model.SubTree is not LabelNavigationNode;
	// Inside an island subtree, every link must swap the full page chrome so the sidebar
	// switches from the parent section's tree to the island's focused tree.
	var navHxAttrs = Model.IsIslandSubtree
		? Model.Htmx.GetHxAttributes(hxSwapOob: "#main-container,#secondary-nav", preload: null)
		: Model.Htmx.GetNavHxAttributes(true, null);
}
@foreach (var item in Model.SubTree.NavigationItems)
{
	if (item.Hidden)
	{
		continue;
	}

	if (item is LabelNavigationNode label)
	{
		var labelBodyIsSubsection = NavV2LabelListKind.IsSubsectionList(label);
		var labelBodyClass = labelBodyIsSubsection
			? "docs-sidebar-nav-v2__subsection"
			: "docs-sidebar-nav-v2__label-children";
		@* Subsection = ul whose direct children are li.relative (nested labels/links), not li.group-navigation folders. *@
		<li class="relative">
			@if (isTopLevel)
			{
				<span class="docs-sidebar-nav-v2__label docs-sidebar-nav-v2__label--top flex items-center px-[12px] py-0 text-sm leading-5 text-[#111C2C]">
					<span class="docs-sidebar-nav-v2__nav-text min-w-0 flex-1">@label.NavigationTitle</span>
				</span>
			}
			else
			{
				<span class="docs-sidebar-nav-v2__label docs-sidebar-nav-v2__label--nested docs-sidebar-nav-v2__nav-text block px-[12px] py-0 text-xs leading-4 uppercase text-[#A2B1C9]">
					@label.NavigationTitle
				</span>
			}
			@if (label.NavigationItems.Count > 0)
			{
				<ul class="@labelBodyClass w-full">
					@await RenderPartialAsync(_TocTreeNavV2.Create(new NavigationTreeItem
					{
						IsPrimaryNavEnabled = Model.IsPrimaryNavEnabled,
						IsGlobalAssemblyBuild = Model.IsGlobalAssemblyBuild,
						Level = Model.Level,
						SubTree = label,
						RootNavigationId = Model.RootNavigationId,
						Htmx = Model.Htmx,
						IsIslandSubtree = Model.IsIslandSubtree
					}))
				</ul>
			}
		</li>
	}
	else if (item is PlaceholderNavigationLeaf placeholder)
	{
		<li class="flex group/li">
			<a
				href="@placeholder.Url"
				@navHxAttrs
				class="sidebar-link nav-v2-link flex w-full items-center gap-2 py-[6px]"
				style="--nav-level:@Model.Level">
				<span class="nav-item-slot shrink-0" aria-hidden="true"></span>
				<span class="docs-sidebar-nav-v2__nav-text min-w-0 flex-1">@placeholder.NavigationTitle</span>
			</a>
		</li>
	}
	else if (item is PlaceholderNavigationNode placeholderGroup)
	{
		var allHidden = placeholderGroup.NavigationItems.All(n => n.Hidden);
		<li class="flex flex-wrap group-navigation relative">
			<div class="peer nav-folder-peer grid w-full grid-cols-1">
				@if (!allHidden)
				{
					<input
						id="@placeholderGroup.Id"
						type="checkbox"
						class="sr-only pointer-events-none"
						tabindex="-1"
						aria-hidden="true">
				}
				<a
					href="@placeholderGroup.Url"
					@navHxAttrs
					class="sidebar-link nav-v2-link flex w-full items-center gap-2 py-[6px]"
					style="--nav-level:@Model.Level">
					@if (!allHidden)
					{
						<span class="nav-folder-chevron shrink-0" aria-hidden="true">
							<svg
								xmlns="http://www.w3.org/2000/svg"
								fill="none"
								viewBox="0 0 24 24"
								stroke-width="1.5"
								stroke="currentColor"
								>
								<path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/>
							</svg>
						</span>
					}
					else
					{
						<span class="nav-item-slot shrink-0" aria-hidden="true"></span>
					}
					<span class="docs-sidebar-nav-v2__nav-text min-w-0 flex-1">@placeholderGroup.NavigationTitle</span>
				</a>
			</div>
			@if (placeholderGroup.NavigationItems.Count > 0)
			{
				<div class="docs-sidebar-nav-v2__folder-clip w-full">
					<div class="docs-sidebar-nav-v2__folder-clip-inner">
						<ul class="docs-sidebar-nav-v2__folder-children w-full relative">
							@await RenderPartialAsync(_TocTreeNavV2.Create(new NavigationTreeItem
							{
								IsPrimaryNavEnabled = Model.IsPrimaryNavEnabled,
								IsGlobalAssemblyBuild = Model.IsGlobalAssemblyBuild,
								Level = Model.Level + 1,
								SubTree = placeholderGroup,
								RootNavigationId = Model.RootNavigationId,
								Htmx = Model.Htmx,
								IsIslandSubtree = Model.IsIslandSubtree
							}))
						</ul>
					</div>
				</div>
			}
		</li>
	}
	else if (item is IslandNavigationNode island)
	{
		var islandHxAttrs = Model.Htmx.GetHxAttributes(hxSwapOob: "#main-container,#secondary-nav", preload: null);
		var islandAllHidden = island.NavigationItems.All(n => n.Hidden);
		<li class="flex flex-wrap group-navigation relative">
			<div class="peer nav-folder-peer grid w-full grid-cols-1">
				@if (!islandAllHidden)
				{
					<input
						id="@island.Id"
						type="checkbox"
						class="sr-only pointer-events-none"
						tabindex="-1"
						aria-hidden="true">
				}
				<a
					href="@island.Url"
					@islandHxAttrs
					class="sidebar-link nav-v2-link flex w-full items-center gap-2 py-[6px]"
					style="--nav-level:@Model.Level">
					@if (!islandAllHidden)
					{
						<span class="nav-folder-chevron shrink-0" aria-hidden="true">
							<svg
								xmlns="http://www.w3.org/2000/svg"
								fill="none"
								viewBox="0 0 24 24"
								stroke-width="1.5"
								stroke="currentColor"
								>
								<path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/>
							</svg>
						</span>
					}
					else
					{
						<span class="nav-item-slot shrink-0" aria-hidden="true"></span>
					}
					<span class="docs-sidebar-nav-v2__nav-text min-w-0 flex-1">@island.NavigationTitle</span>
				</a>
			</div>
			@if (island.NavigationItems.Count > 0)
			{
				<div class="docs-sidebar-nav-v2__folder-clip w-full">
					<div class="docs-sidebar-nav-v2__folder-clip-inner">
						<ul class="docs-sidebar-nav-v2__folder-children w-full relative">
							@await RenderPartialAsync(_TocTreeNavV2.Create(new NavigationTreeItem
							{
								IsPrimaryNavEnabled = Model.IsPrimaryNavEnabled,
								IsGlobalAssemblyBuild = Model.IsGlobalAssemblyBuild,
								Level = Model.Level + 1,
								SubTree = island,
								RootNavigationId = Model.RootNavigationId,
								Htmx = Model.Htmx,
								IsIslandSubtree = true
							}))
						</ul>
					</div>
				</div>
			}
		</li>
	}
	else if (item is INodeNavigationItem<INavigationModel, INavigationItem> { NavigationItems.Count: 0 } group)
	{
		<li class="flex group/li">
			<a
				href="@group.Url"
				@navHxAttrs
				class="sidebar-link nav-v2-link flex w-full items-center gap-2 py-[6px]"
				style="--nav-level:@Model.Level"
			>
				<span class="nav-item-slot shrink-0" aria-hidden="true"></span>
				<span class="docs-sidebar-nav-v2__nav-text min-w-0 flex-1">@group.NavigationTitle</span>
			</a>
		</li>
	}
	else if (item is INodeNavigationItem<INavigationModel, INavigationItem> folder)
	{
		var allHidden = folder.NavigationItems.All(n => n.Hidden);
		<li class="flex flex-wrap group-navigation relative">
			<div class="peer nav-folder-peer grid w-full grid-cols-1">
				@if (!allHidden)
				{
					<input
						id="@folder.Id"
						type="checkbox"
						class="sr-only pointer-events-none"
						tabindex="-1"
						aria-hidden="true">
				}
				<a
					href="@(folder.Url)"
					@navHxAttrs
					class="sidebar-link nav-v2-link flex w-full items-center gap-2 py-[6px]"
					style="--nav-level:@Model.Level">
					@if (!allHidden)
					{
						<span class="nav-folder-chevron shrink-0" aria-hidden="true">
							<svg
								xmlns="http://www.w3.org/2000/svg"
								fill="none"
								viewBox="0 0 24 24"
								stroke-width="1.5"
								stroke="currentColor"
								>
								<path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/>
							</svg>
						</span>
					}
					else
					{
						<span class="nav-item-slot shrink-0" aria-hidden="true"></span>
					}
					<span class="docs-sidebar-nav-v2__nav-text min-w-0 flex-1">@(folder.NavigationTitle)</span>
				</a>
			</div>
			@if (folder.NavigationItems.Count > 0)
			{
				<div class="docs-sidebar-nav-v2__folder-clip w-full">
					<div class="docs-sidebar-nav-v2__folder-clip-inner">
						<ul class="docs-sidebar-nav-v2__folder-children w-full relative">
							@await RenderPartialAsync(_TocTreeNavV2.Create(new NavigationTreeItem
							{
								IsPrimaryNavEnabled = Model.IsPrimaryNavEnabled,
								IsGlobalAssemblyBuild = Model.IsGlobalAssemblyBuild,
								Level = Model.Level + 1,
								SubTree = folder,
								RootNavigationId = Model.RootNavigationId,
								Htmx = Model.Htmx,
								IsIslandSubtree = Model.IsIslandSubtree
							}))
						</ul>
					</div>
				</div>
			}
		</li>
	}
	else if (item is ILeafNavigationItem<INavigationModel> leaf)
	{
		<li class="flex group/li">
			<a
				href="@leaf.Url"
				@navHxAttrs
				class="sidebar-link nav-v2-link flex w-full items-center gap-2 py-[6px]"
				style="--nav-level:@Model.Level"
			>
				<span class="nav-item-slot shrink-0" aria-hidden="true"></span>
				<span class="docs-sidebar-nav-v2__nav-text min-w-0 flex-1">@leaf.NavigationTitle</span>
			</a>
		</li>
	}
}

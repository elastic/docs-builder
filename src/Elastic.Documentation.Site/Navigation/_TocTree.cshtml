@using Elastic.Documentation
@using Elastic.Documentation.Site.Navigation
@using Elastic.Documentation.Navigation
@inherits RazorSlice<Elastic.Documentation.Site.Navigation.NavigationViewModel>

@{
	var currentTopLevelItem = Model.TopLevelItems.FirstOrDefault(i => i.Id == Model.Tree.Id) ?? Model.Tree;
	var showBack = Model.BackArrowUrl is not null;
	var showSearch = Model.BuildType != BuildType.Codex
		&& Model.Branding is null
		&& !Model.IsIsolatedSection
		&& !showBack
		&& Model.SectionUrl is null;
	var isYamlIsolatedSection = Model.IsIsolatedSection && !showBack;
}

@* Figma Nav component: optional Search + optional Back + scrollable Content (Top / Subtitle / List). *@
<div
	class="pages-nav-v2-shell flex min-h-0 flex-1 min-w-[279px] flex-col pl-3 font-body md:pl-0"
	data-nav-search="@(showSearch ? "true" : "false")"
	data-nav-back="@(showBack ? "true" : "false")"
	data-nav-isolated="@(isYamlIsolatedSection ? "true" : "false")">
	@if (showSearch)
	{
		<div id="pages-nav-sticky-chrome">
			<navigation-search></navigation-search>
		</div>
	}

	@if (showBack)
	{
		<a
			href="@Model.BackArrowUrl"
			@Model.Htmx.GetHxAttributes(
				hxSwapOob: "#main-container,#secondary-nav,#pages-nav",
				preload: null)
			class="pages-nav-v2__back mt-6 flex min-h-[34px] shrink-0 items-center gap-2 rounded-[6px] px-2 py-[7px] text-sm leading-5 text-[#516381] hover:text-[#1d2a3e]">
			<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4 shrink-0" aria-hidden="true">
				<path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/>
			</svg>
			<span>Back</span>
		</a>
	}

	<div class="pages-nav-menu pages-nav-v2__scroll min-h-0 min-w-[279px] flex-1 overflow-y-auto">
		<div class="pages-nav-v2__content flex w-[260px] min-w-0 flex-col">
			@if (!Model.IsNavV2)
			{
				<div id="nav-dropdown">
					@if (Model.IsUsingNavigationDropdown)
					{
						<div class="py-4 bg-white border-grey-20 pr-4">
							<div tabindex="0" id="pages-dropdown" class="block group border border-grey-20 rounded-sm font-sans relative">
								<button class="w-full text-left grid grid-cols-[1fr_auto] cursor-pointer font-semibold gap-1 hover:text-black pl-4 pr-2 py-2 group-open:border-b-1 border-grey-20">
									<div>
										<a
											class="pages-dropdown_active inline-block px-[8px] py-[6px] hover:underline text-blue-elastic hover:text-blue-elastic-100"
											href="@currentTopLevelItem.Url"
											@Model.Htmx.GetNavHxAttributes(true)>
											@currentTopLevelItem.NavigationTitle
										</a>
									</div>
									<div class="flex items-center justify-center size-6 hover:bg-grey-20 rounded-sm">
										<svg
											xmlns="http://www.w3.org/2000/svg"
											fill="none"
											viewBox="0 0 24 24"
											stroke-width="1.5"
											stroke="currentColor"
											class="w-4 group-open:rotate-180">
											<path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/>
										</svg>
									</div>
								</button>
								<div class="hidden group-focus-within:block left-0 right-0 absolute top-full">
									<ul class="mt-1 py-2 bg-white border-1 border-grey-20 rounded-sm shadow-md">
										@foreach (var item in Model.TopLevelItems)
										{
											<li class="block">
												<a
													class="block px-[8px] py-[6px] hover:underline hover:text-black hover:bg-grey-10 active:bg-blue-elastic-70 active:text-white font-semibold @(item.NavigationRoot.Id == Model.Tree.Id ? "text-blue-elastic" : "")"
													href="@item.Url"
													@Model.Htmx.GetNavHxAttributes(false, "mouseover")>
													@item.NavigationTitle
												</a>
											</li>
										}
									</ul>
								</div>
							</div>
						</div>
					}
				</div>
				<ul class="block px-4" id="nav-tree">
					@await RenderPartialAsync(_TocTreeNav.Create(new NavigationTreeItem
					{
						IsPrimaryNavEnabled = Model.IsPrimaryNavEnabled,
						IsGlobalAssemblyBuild = Model.IsGlobalAssemblyBuild,
						Level = 0,
						SubTree = Model.Tree,
						RootNavigationId = Model.Tree.Id,
						Htmx = Model.Htmx
					}))
				</ul>
			}
			else
			{
				<nav class="docs-sidebar-nav-v2" data-nav-v2 @if (Model.SectionUrl is not null) { <text>data-section-url="@Model.SectionUrl"</text> }>
					<ul class="docs-sidebar-nav-v2__tree block" id="nav-tree">
						@await RenderPartialAsync(_TocTreeNavV2.Create(new NavigationTreeItem
						{
							IsPrimaryNavEnabled = Model.IsPrimaryNavEnabled,
							IsGlobalAssemblyBuild = Model.IsGlobalAssemblyBuild,
							Level = 0,
							SubTree = Model.Tree,
							RootNavigationId = Model.Tree.Id,
							Htmx = Model.Htmx,
							IsIslandSubtree = showBack
						}))
					</ul>
				</nav>
			}
		</div>
	</div>
</div>

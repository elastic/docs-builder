@inherits RazorSlice<Elastic.Markdown.Myst.Directives.Hub.HeroViewModel>

<section class="hub-hero">
	<div class="hub-hero-inner">
		@if (!string.IsNullOrWhiteSpace(Model.Title))
		{
			<div class="hub-hero-eyebrow">
				<span class="hub-hero-eyebrow-label">Find all docs about @Model.Title</span>
				<a class="hub-hero-eyebrow-link" href="@Model.PrefixUrl("/")" hx-boost="false">
					<span>Browse all Elastic docs</span>
					<svg class="hub-hero-eyebrow-arrow" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
						<path d="M3 8h9M8.5 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
				</a>
			</div>
		}
		<div class="hub-hero-top">
			@if (!string.IsNullOrWhiteSpace(Model.IconSvg))
			{
				<span class="hub-hero-icon hub-hero-icon-svg">
					@(new HtmlString(Model.IconSvg))
				</span>
			}
			else if (!string.IsNullOrWhiteSpace(Model.IconKey))
			{
				<span class="hub-hero-icon" aria-hidden="true">@Elastic.Markdown.Myst.Directives.Hub.ProductIcons.Initials(Model.IconKey)</span>
			}
			<div class="hub-hero-title">
				<h1>@Model.Title</h1>
				@if (!string.IsNullOrWhiteSpace(Model.DescriptionHtml))
				{
					<p>@(new HtmlString(Model.DescriptionHtml))</p>
				}
			</div>
		</div>

		@if (!string.IsNullOrWhiteSpace(Model.ReleasesHtml))
		{
			<p class="hub-hero-releases">@(new HtmlString(Model.ReleasesHtml))</p>
		}
	</div>
</section>

@inherits RazorSlice<Elastic.Markdown.Myst.Directives.Hub.OnThisPageViewModel>

@if (Model.Items.Count > 0)
{
	<nav class="hub-on-this-page" aria-label="On this page">
		<span class="hub-on-this-page-label">On this page</span>
		@for (var i = 0; i < Model.Items.Count; i++)
		{
			var item = Model.Items[i];
			<a href="@($"#{item.Anchor}")">@item.Title</a>
			@if (i < Model.Items.Count - 1)
			{
				<span class="hub-on-this-page-sep" aria-hidden="true">·</span>
			}
		}
	</nav>
}

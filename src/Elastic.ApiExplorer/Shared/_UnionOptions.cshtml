@using Elastic.ApiExplorer.Schema
@inherits RazorSlice<Elastic.ApiExplorer.Schema.ApiUnionVariants>
@{
	if (Model.Variants.Count == 0)
	{
		return;
	}
}
<div class="union-variants-container @(Model.ShouldCollapse ? "collapsible collapsed" : "")" id="@Model.ContainerId">
	@if (Model.ShouldCollapse)
	{
		<div class="union-collapse-toggle">
			<button class="expand-toggle union-group-toggle">
				<span class="toggle-icon">+</span>
				<span class="toggle-label">Show @Model.Variants.Count type options</span>
			</button>
		</div>
	}
	<div class="union-variants @(Model.ShouldCollapse ? "union-variants-content" : "")" @(Model.ShouldCollapse && Model.UseHiddenUntilFound ? "hidden=\"until-found\"" : "")>
	@for (var i = 0; i < Model.Variants.Count; i++)
	{
		var variant = Model.Variants[i];

		// Add separator before each variant except the first
		@if (i > 0)
		{
			<div class="union-separator">or</div>
		}

		<div class="union-variant-item @(variant.ShowProperties ? "has-children" : "") @(variant.IsCollapsible ? (variant.DefaultExpanded ? "expanded" : "collapsed") : "")" id="@variant.AnchorId">
			<div class="union-variant-label">
				@if (variant.IsArrayVariant)
				{
					<span class="array-icon">[]</span>
				}
				@if (variant.IsObjectType)
				{
					<span class="object-icon">{}</span>
				}
				<code class="schema-type">@variant.DisplayName</code>
			</div>
			@if (variant.ShowProperties && variant.Properties is not null)
			{
				if (variant.IsCollapsible)
				{
					<div class="expand-toggle-row union-expand-toggle">
						<button class="expand-toggle">
							<span class="toggle-icon">@(variant.DefaultExpanded ? "−" : "+")</span>
							<span class="toggle-label">@(variant.DefaultExpanded ? "Hide" : "Show") @variant.NestedCount properties</span>
						</button>
					</div>
				}
				if (variant.UseHidden)
				{
					<div class="nested-properties" id="@variant.AnchorId-children" hidden="until-found">
						@(await RenderPartialAsync<_PropertyList, ApiPropertyList>(variant.Properties))
					</div>
				}
				else
				{
					<div class="nested-properties" id="@variant.AnchorId-children">
						@(await RenderPartialAsync<_PropertyList, ApiPropertyList>(variant.Properties))
					</div>
				}
			}
		</div>
	}
	</div>
</div>

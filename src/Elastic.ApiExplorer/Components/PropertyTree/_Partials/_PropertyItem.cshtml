@inherits RazorSlice<Elastic.ApiExplorer.Components.PropertyTree.ApiProperty>
@{
	var hasChildren = Model.Children.Kind != ChildKind.None;
}
<div class="property-item depth-@Model.Depth @(Model.IsLast ? "last-sibling" : "") @(hasChildren ? "has-children" : "") @(Model.IsCollapsible ? (Model.DefaultExpanded ? "expanded" : "collapsed") : "") @(Model.ShowDeprecatedBadge ? "deprecated" : "")">
	<dt id="@Model.AnchorId">
		<a href="#@Model.AnchorId">
			<code>@Model.Name</code>
			@(await RenderPartialAsync<_SchemaType, TypeAnnotation>(Model.Type))
			@if (Model.IsRequest && Model.IsRequired)
			{
				<span class="required">required</span>
			}
			else if (!Model.IsRequest && !Model.IsRequired)
			{
				<span class="optional">optional</span>
			}
			@if (Model.IsRecursive)
			{
				@(await RenderPartialAsync<_RecursiveBadge>())
			}
			@if (Model.ShowDeprecatedBadge)
			{
				<span class="deprecated-badge">deprecated</span>
			}
		@if (Model.Availability is not null)
		{
			@(await RenderPartialAsync<_AppliesToBadge, Elastic.ApiExplorer.Infrastructure.AppliesToBadgeDisplay>(new Elastic.ApiExplorer.Infrastructure.AppliesToBadgeDisplay(Model.Availability, IsInline: true)))
		}
		</a>
	</dt>
	@if (Model.HasDescription)
	{
		<dd>
			@Model.DescriptionHtml
		</dd>
	}
	@if (Model.ExternalDocs is not null)
	{
		<dd class="external-docs-row">
			<a href="@Model.ExternalDocs.Url" class="docs-reference-btn docs-reference-btn-sm" @(Model.ExternalDocs.IsElasticDocs ? "" : "target=\"_blank\" rel=\"noopener\"")>
				@Model.ExternalDocs.LinkText
			</a>
		</dd>
	}
	@(await RenderPartialAsync<_ValidationConstraints, IReadOnlyList<ConstraintDisplay>>(Model.Constraints))
	@if (Model.EnumValues.Count > 0)
	{
		<dd class="enum-values">
			<span class="values-label">Values:</span>
			@foreach (var enumVal in Model.EnumValues)
			{
				<code class="enum-value">@enumVal</code>
			}
		</dd>
	}
	@if (Model.Union is not null)
	{
		if (Model.Union.Kind == UnionDisplayKind.EnumLike)
		{
			<dd class="enum-values">
				<span class="values-label">Values:</span>
				@foreach (var enumVal in Model.Union.EnumLikeValues)
				{
					<code class="enum-value">@enumVal</code>
				}
			</dd>
		}
		else if (Model.Union.Kind == UnionDisplayKind.SimpleArrayUnion)
		{
			<dd class="union-inline-row">
				<span class="values-label">One of:</span>
				<span class="union-inline-options">
					<span class="union-inline-option">
						@if (Model.Union.SimpleUnionIsObject)
						{
							<span class="object-icon">{}</span>
						}
						<code class="schema-type"><span>@Model.Union.SimpleUnionValueTypePrefix@Model.Union.SimpleUnionBaseName</span></code>
					</span>
					<span class="union-inline-separator">or</span>
					<span class="union-inline-option">
						<span class="array-icon">[]</span>
						@if (Model.Union.SimpleUnionIsObject)
						{
							<span class="object-icon">{}</span>
						}
						<code class="schema-type"><span>@Model.Union.SimpleUnionValueTypePrefix@Model.Union.SimpleUnionBaseName</span></code>
					</span>
				</span>
			</dd>
		}
		else if (Model.Union.Kind == UnionDisplayKind.Badges)
		{
			<dd class="union-options">
				<span class="values-label">One of:</span>
				@if (Model.Union.DiscriminatorProperty != null)
				{
					<span class="discriminator-note">(determined by <code>@Model.Union.DiscriminatorProperty</code>)</span>
				}
				@for (var badgeIndex = 0; badgeIndex < Model.Union.Badges.Count; badgeIndex++)
				{
					var badge = Model.Union.Badges[badgeIndex];
					if (badgeIndex > 0)
					{
						<span class="union-inline-separator">or</span>
					}
					<code class="@(badge.IsTypeOption ? "union-type-option" : "union-option")">@badge.Text</code>
				}
			</dd>
		}
	}
	@if (Model.ArrayItemTypeName != null)
	{
		<dd class="primitive-array">
			<span class="values-label">Array of:</span>
			<code class="primitive-type">@Model.ArrayItemTypeName</code>
		</dd>
	}
	@if (Model.TypeLink is not null)
	{
		<dd class="type-link-description">
			<a href="@Model.TypeLink.Url" data-hx-boost="false">See @Model.TypeLink.TypeName type →</a>
		</dd>
	}
	@if (Model.IsCollapsible)
	{
		<dd class="expand-toggle-row">
			<button class="expand-toggle" aria-expanded="@(Model.DefaultExpanded ? "true" : "false")" aria-controls="@Model.AnchorId-children" title="@(Model.DefaultExpanded ? "Collapse" : "Expand") @Model.NestedCount properties">
				<span class="toggle-icon">@(Model.DefaultExpanded ? "−" : "+")</span>
				<span class="toggle-label">@(Model.DefaultExpanded ? "Hide" : "Show") @Model.NestedCount properties</span>
			</button>
		</dd>
	}
	@if (Model.Children.Kind == ChildKind.Dictionary)
	{
		var dict = Model.Children.Dictionary!;
			<div class="nested-properties" id="@Model.AnchorId-children">
				<dl class="property-list">
					<div class="property-item depth-@dict.Depth last-sibling has-children @(dict.IsCollapsible ? (dict.DefaultExpanded ? "expanded" : "collapsed") : "")">
						<dt id="@dict.KeyAnchorId">
							<code>&lt;string&gt;</code>
							@(await RenderPartialAsync<_SchemaType, TypeAnnotation>(dict.ValueType))
						</dt>
						@if (dict.IsCollapsible)
						{
							<dd class="expand-toggle-row">
								<button class="expand-toggle" aria-expanded="@(dict.DefaultExpanded ? "true" : "false")" aria-controls="@dict.KeyAnchorId-children" title="@(dict.DefaultExpanded ? "Collapse" : "Expand") @dict.NestedCount properties">
									<span class="toggle-icon">@(dict.DefaultExpanded ? "−" : "+")</span>
									<span class="toggle-label">@(dict.DefaultExpanded ? "Hide" : "Show") @dict.NestedCount properties</span>
								</button>
							</dd>
						}
						@if (dict.UseHidden)
						{
							<div class="nested-properties" id="@dict.KeyAnchorId-children" hidden="until-found">
								@(await RenderPartialAsync<_PropertyList, ApiPropertyList>(dict.Properties))
							</div>
						}
						else
						{
							<div class="nested-properties" id="@dict.KeyAnchorId-children">
								@(await RenderPartialAsync<_PropertyList, ApiPropertyList>(dict.Properties))
							</div>
						}
					</div>
				</dl>
			</div>
	}
	else if (Model.Children.Kind == ChildKind.PropertyList)
	{
		if (Model.Children.UseHidden)
		{
				<div class="nested-properties" id="@Model.AnchorId-children" hidden="until-found">
					@(await RenderPartialAsync<_PropertyList, ApiPropertyList>(Model.Children.Properties!))
				</div>
		}
		else
		{
				<div class="nested-properties" id="@Model.AnchorId-children">
					@(await RenderPartialAsync<_PropertyList, ApiPropertyList>(Model.Children.Properties!))
				</div>
		}
	}
	else if (Model.Children.Kind == ChildKind.UnionVariants)
	{
			<div class="nested-properties" id="@Model.AnchorId-children">
				@(await RenderPartialAsync<_UnionOptions, ApiUnionVariants>(Model.Children.Variants!))
			</div>
	}
	else if (Model.Children.Kind == ChildKind.SimpleUnionVariants)
	{
		if (Model.Children.UseHidden)
		{
				<div class="nested-properties" id="@Model.AnchorId-children" hidden="until-found">
					@(await RenderPartialAsync<_UnionOptions, ApiUnionVariants>(Model.Children.Variants!))
				</div>
		}
		else
		{
				<div class="nested-properties" id="@Model.AnchorId-children">
					@(await RenderPartialAsync<_UnionOptions, ApiUnionVariants>(Model.Children.Variants!))
				</div>
		}
	}
</div>

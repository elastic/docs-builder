<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <AssemblyName>Elastic.Documentation.Search.Contract</AssemblyName>
        <RootNamespace>Elastic.Documentation.Search.Contract</RootNamespace>
        <IsAotCompatible>true</IsAotCompatible>
        <!-- The contract deliberately exposes two namespaces (root + .Mapping) over
             concern-based folders (Common/, Search/, Site/, ...) -->
        <NoWarn>$(NoWarn);IDE0130</NoWarn>
    </PropertyGroup>

    <ItemGroup>
      <PackageReference Include="Elastic.Mapping" />
    </ItemGroup>

</Project>

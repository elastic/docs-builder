      "Bash(npm run fmt::*)",
      "Bash(npm run test:*)",
      "Bash(npm run watch:*)",
      "Bash(npm run build:*)",
      "Bash(npm exec:*)",
      "Bash(npm install:*)",
      "Bash(npx tsc:*)",

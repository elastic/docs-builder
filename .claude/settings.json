      "Bash(pnpm run compile:check:*)",
      "Bash(pnpm run lint:*)",
      "Bash(pnpm run fmt::*)",
      "Bash(pnpm run test:*)",
      "Bash(pnpm run watch:*)",
      "Bash(pnpm run build:*)",
      "Bash(pnpm exec:*)",
      "Bash(pnpm import:*)",
      "Bash(git add:*)",

<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!-- Local feed for Elastic.Internal.Search.* packages produced by sibling website-search-data repo.
         Override via env var or by replacing this path until packages ship to a real feed. -->
    <add key="website-search-data-local" value="../../../website-ai-search/feature/search-contract/.artifacts/packages" />
  </packageSources>
</configuration>
